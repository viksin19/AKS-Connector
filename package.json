{
  "name": "aks-connector",
  "version": "1.0.0",
  "description": "A local desktop application for managing Azure Kubernetes Service (AKS) clusters",
  "main": "electron/main.js",
  "homepage": "./",
  "author": {
    "name": "AKS Connector Team",
    "email": "aks-connector@example.com"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && go run main.go",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"wait-on http://localhost:8080 && npm run dev:electron\"",
    
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && go build -o aks-connector.exe main.go",
    "build:backend-linux": "cd backend && GOOS=linux GOARCH=amd64 go build -o aks-connector main.go",
    "build:backend-mac": "cd backend && GOOS=darwin GOARCH=amd64 go build -o aks-connector main.go",
    "build:all": "npm run build:frontend && npm run build:backend",
    
    "electron:pack": "electron-builder",
    "electron:pack-win": "electron-builder --win",
    "electron:pack-mac": "electron-builder --mac",
    "electron:pack-linux": "electron-builder --linux",
    
    "prepackage": "npm run build:all",
    "package": "npm run electron:pack",
    "package:win": "npm run build:all && npm run electron:pack-win",
    "package:mac": "npm run build:all && npm run build:backend-mac && npm run electron:pack-mac",
    "package:linux": "npm run build:all && npm run build:backend-linux && npm run electron:pack-linux",
    
    "install:all": "npm install && cd frontend && npm install && cd ../backend && go mod tidy",
    "clean": "rimraf dist build frontend/dist backend/aks-connector*",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.aks-connector.app",
    "productName": "AKS Connector",
    "copyright": "Copyright © 2026 AKS Connector Team",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "backend/aks-connector*",
      "!backend/*.go",
      "!backend/go.mod",
      "!backend/go.sum",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend/aks-connector*",
        "to": "backend/",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "publisherName": "AKS Connector Team"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "assets/icon.icns",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.png",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AKS Connector"
    }
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "wait-on": "^7.2.0",
    "rimraf": "^5.0.5"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "kubernetes",
    "aks",
    "azure",
    "kubectl",
    "cluster-management",
    "desktop-app",
    "electron",
    "react",
    "go"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/aks-connector.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/aks-connector/issues"
  }
}